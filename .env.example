# Database
DATABASE_URL=postgresql+asyncpg://maskai:maskai@localhost:5432/maskai
DATABASE_URL_SYNC=postgresql://maskai:maskai@localhost:5432/maskai

# JWT
JWT_SECRET_KEY=change-me-to-random-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# Encryption (Fernet key: base64-encoded 32 bytes)
ENCRYPTION_KEY=

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# App
APP_URL=http://localhost:8000
ENV=development
